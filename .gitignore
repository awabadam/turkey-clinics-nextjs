# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (match in any subdirectory)
node_modules/
.pnp
.pnp.js

# testing
coverage/

# build outputs (match in any subdirectory)
dist/
build/
out/

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files - never commit real .env
.env*.local
.env
!.env.example

# ignore null values (Windows)
nul


# typescript
*.tsbuildinfo

# prisma
/prisma/migrations

# uploads
/public/uploads/*
!/public/uploads/.gitkeep
.next/
