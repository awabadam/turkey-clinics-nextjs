# Database
# For local development without Docker:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/turkey_clinic_guide?schema=public

# For Docker deployment, this is set automatically by docker-compose.yml
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/turkey_clinic_guide?schema=public

# Backend Configuration
# JWT Secret - Generate a secret with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Server Port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Google Maps API Key (optional - required for map display on clinic pages)
# Get your key from: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Frontend API URL
VITE_API_URL=http://localhost:3001/api

# Email Service (optional - for booking notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Turkey Clinic Guide <noreply@turkeyclinicguide.com>"
ADMIN_EMAIL=admin@turkeyclinicguide.com
