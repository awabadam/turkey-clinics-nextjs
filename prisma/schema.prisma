// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
  CLINIC_OWNER
}

enum ClinicStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id            String    @id  // Supabase Auth UUID
  email         String    @unique
  name          String?
  role          UserRole  @default(USER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviews       Review[]
  bookings      Booking[]
  favorites     Favorite[]
  ownedClinic   Clinic?
}

model Clinic {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  description      String?   @db.Text
  address          String
  city             String
  phone            String
  email            String?
  website          String?
  latitude         Float?
  longitude        Float?
  services         String[]  @default([])
  languages        String[]  @default([])
  certifications   String[]  @default([])
  accreditations   String[]  @default([])
  doctorCount      Int?
  establishedYear Int?
  beforeAfterImages String[] @default([])
  trustBadges       String[] @default([])
  testimonials      Json?     // Store as JSON array: [{ name: string, text: string, rating: number }]
  successStories    String[]  @default([])
  hours            Json?     // Store as JSON: { monday: { open: "09:00", close: "18:00" }, ... }
  images           String[]  @default([])
  featured         Boolean   @default(false)
  status           ClinicStatus @default(PENDING_APPROVAL)
  ownerId          String?      @unique
  owner            User?        @relation(fields: [ownerId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  reviews          Review[]
  bookings         Booking[]
  procedures       Procedure[]
  favorites        Favorite[]
  views            ClinicView[]

  @@index([city])
  @@index([slug])
  @@index([featured])
}

model ClinicView {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@index([clinicId])
  @@index([createdAt])
}

model Review {
  id               String    @id @default(cuid())
  rating           Int       // 1-5
  comment          String?   @db.Text
  reviewCategories Json?     // { cleanliness: number, staff: number, results: number, value: number }
  reviewImages     String[]  @default([])
  verified         Boolean   @default(false)
  clinicResponse   String?   @db.Text
  clinicResponseDate DateTime?
  userId           String
  clinicId         String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic           Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([userId])
}

model Booking {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String?       @db.Text
  preferredDate DateTime?
  status    BookingStatus @default(PENDING)
  clinicId  String
  userId    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  clinic    Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([status])
}

model Procedure {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  averagePrice Float?
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  clinicId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([userId])
  @@index([clinicId])
}

